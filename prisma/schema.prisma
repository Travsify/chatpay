generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== CORE USER =====
model User {
  id               String   @id @default(uuid())
  phoneNumber      String   @unique
  name             String?
  kycStatus        KycStatus @default(PENDING)
  tier             Int      @default(0)
  fincraWalletId   String?
  fincraCustomerId String?
  suspended        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions     Transaction[]
  sessions         Session[]
  conversations    ConversationLog[]
  virtualAccounts  VirtualAccount[]
}

// ===== TRANSACTIONS =====
model Transaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  currency    String   @default("NGN")
  status      TransactionStatus @default(PENDING)
  reference   String   @unique
  provider    String   // FINCRA, FLUTTERWAVE
  description String?
  createdAt   DateTime @default(now())
}

// ===== SESSION STATE =====
model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  currentState String   @default("START")
  context      String?  // JSON string for step-specific data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===== ADMIN USERS (God Mode Access) =====
model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         AdminRole @default(OPERATOR)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===== CONVERSATION LOGS (AI Chat History) =====
model ConversationLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  direction   MessageDirection
  message     String
  intent      String?  // Detected AI intent
  aiResponse  String?  // What the AI responded with
  confidence  Float?   // AI confidence score
  createdAt   DateTime @default(now())
}

// ===== WEBHOOK LOGS (Message Delivery Tracking) =====
model WebhookLog {
  id          String   @id @default(uuid())
  direction   MessageDirection
  phoneNumber String
  payload     String   // JSON payload
  status      WebhookStatus @default(RECEIVED)
  errorMsg    String?
  latencyMs   Int?
  createdAt   DateTime @default(now())
}

// ===== VIRTUAL ACCOUNTS =====
model VirtualAccount {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  accountNumber String
  bankName      String   @default("WEMA BANK")
  currency      String   @default("NGN")
  provider      String   @default("FINCRA")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ===== ENUMS =====
enum KycStatus {
  PENDING
  VERIFIED
  FAILED
}

enum TransactionType {
  P2P_SEND
  P2P_RECEIVE
  BILL_PAYMENT
  AIRTIME
  FUNDING
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AdminRole {
  SUPER_ADMIN
  OPERATOR
  VIEWER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}
