generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ===== CORE USER =====
model User {
  id               String            @id @default(uuid())
  phoneNumber      String            @unique
  name             String?
  email            String?
  bvn              String?
  kycStatus         KycStatus         @default(PENDING)
  tier             Int               @default(0)
  fincraWalletId   String?
  fincraCustomerId String?
  mapleradCustomerId String?
  suspended        Boolean           @default(false)
  transactionPin   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  transactions     Transaction[]
  sessions         Session[]
  scheduledTasks   ScheduledTask[]
  conversations    ConversationLog[]
  virtualAccounts  VirtualAccount[]
  businessKyb      BusinessKyb?
  vouchers         Voucher[]
}

// ===== TRANSACTIONS =====
model Transaction {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  amount      Float
  currency    String            @default("NGN")
  status      TransactionStatus @default(PENDING)
  reference   String            @unique
  provider    String // FINCRA, FLUTTERWAVE
  description String?
  createdAt   DateTime          @default(now())
}

// ===== SESSION STATE =====
model Session {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  currentState String   @default("START")
  context      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===== ADMIN USERS (God Mode Access) =====
model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(OPERATOR)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ===== CONVERSATION LOGS (AI Chat History) =====
model ConversationLog {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  direction  MessageDirection
  message    String           @db.Text
  intent     String? // Detected AI intent
  aiResponse String?          @db.Text
  confidence Float? // AI confidence score
  createdAt  DateTime         @default(now())
}

// ===== WEBHOOK LOGS (Message Delivery Tracking) =====
model WebhookLog {
  id          String           @id @default(uuid())
  direction   MessageDirection
  phoneNumber String
  payload     String           @db.Text
  status      WebhookStatus    @default(RECEIVED)
  errorMsg    String?          @db.Text
  latencyMs   Int?
  createdAt   DateTime         @default(now())
}

// ===== VIRTUAL ACCOUNTS =====
model VirtualAccount {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  accountNumber String
  bankName      String   @default("WEMA BANK")
  currency      String   @default("NGN")
  provider      String   @default("FINCRA")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ===== SYSTEM CONFIGURATION (API VAULT) =====
model SystemConfig {
  id              String   @id @default("global")
  whatsappNumber  String?
  premblySecret   String?
  openaiKey       String?
  fincraSecret      String?
  fincraWebhookSecret String?
  flutterwaveSecret String?
  whapiToken        String?
  whapiApiUrl       String?
  whapiWebhookUrl   String?
  quidaxSecret      String?
  prestmitSecret    String?
  mapleradSecret    String?
  bitnobApiKey        String?
  
  // Financial Rules & Granular Markups
  feePercentage     Float    @default(0.5)
  flatFee           Float    @default(50.0)
  dailyLimit        Float    @default(500000.0)
  
  // Fiat Markups
  usdExchangeRate   Float    @default(1500.0)
  usdMarkup          Float    @default(50.0)
  gbpMarkup         Float    @default(80.0)
  
  // Asset Markups
  cryptoMarkupPerc  Float    @default(2.0)  // 2% markup on Quidax rates
  giftcardMarkupPerc Float   @default(5.0)  // 5% markup on PressMnt rates
  cardIssuanceFee   Float    @default(1500.0) // ₦1,500 startup fee for cards
  cardFundingMarkup Float    @default(20.0)   // ₦20 per dollar markup for funding cards
  
  updatedAt         DateTime @updatedAt
}

// ===== SCHEDULED TASKS (Automation) =====
model ScheduledTask {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // e.g., "BUY_THE_DIP", "TRANSFER"
  amount      Float    @default(0)
  currency    String   @default("NGN")
  reference   String   @unique
  status      String   @default("PENDING")
  targetDate  DateTime
  context     String?  @db.Text
  createdAt   DateTime @default(now())
}

// ===== VOUCHERS (Minted Assets) =====
model Voucher {
  id          String   @id @default(uuid())
  createdById String
  user        User     @relation(fields: [createdById], references: [id])
  code        String   @unique
  amount      Float
  currency    String   @default("NGN")
  status      String   @default("ACTIVE") // ACTIVE, REDEEMED, CANCELLED
  isRedeemed  Boolean  @default(false)
  redeemedAt  DateTime?
  createdAt   DateTime @default(now())
}

// ===== BUSINESS KYB (PREMBLY) =====
model BusinessKyb {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  cacNumber       String
  companyName     String?
  directors       String?   @db.Text
  status          KycStatus @default(PENDING)
  premblyRef      String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ===== ENUMS =====
enum KycStatus {
  PENDING
  VERIFIED
  FAILED
}

enum TransactionType {
  P2P_SEND
  P2P_RECEIVE
  BILL_PAYMENT
  AIRTIME
  FUNDING
  TRANSFER
  ESCROW
  VOUCHER_REDEEM
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AdminRole {
  SUPER_ADMIN
  OPERATOR
  VIEWER
}

enum Role {
  USER
  OPERATOR
  SUPER_ADMIN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}


